{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "variants": {
            "none": {
              "disabled": true
            },
            "low": {
              "disabled": true,
            },
            "medium": {
              "disabled": true,
            },
            "high": {
              "disabled": true
            }
          },
        },
      },
    },
  },
  "lsp": {
    "ruff": {
      "command": [
        "ruff",
        "server"
      ],
      "extensions": [
        ".py"
      ]
    },
    "ty": {
      "command": [
        "ty",
        "server"
      ],
      "extensions": [
        ".py"
      ]
    },
    "pyright": {
      "disabled": true
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    }
  },
  "permission": {
    "external_directory": {
      "~/**": "allow"
    }
  }
}
